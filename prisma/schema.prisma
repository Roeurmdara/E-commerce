// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Auth.js / NextAuth Models
// ============================================================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// User & Role Models
// ============================================================================

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  password      String?     // For custom auth, nullable for OAuth
  emailVerified DateTime?
  image         String?
  role          UserRole    @default(CUSTOMER)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Auth relations
  accounts      Account[]
  sessions      Session[]

  // Customer relations
  cart          CartItem[]
  wishlist      Wishlist[]
  orders        Order[]
  reviews       Review[]

  // Seller relations
  sellerProfile SellerProfile?
  products      Product[]
  sellerOrders  Order[]         @relation("SellerOrders")
  
  // Admin relations
  managedUsers  User[]          @relation("AdminUsers")
  managedBy     User?           @relation("AdminUsers", fields: [managedById], references: [id])
  managedById   String?

  @@index([role])
  @@index([email])
}

model SellerProfile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  storeName           String
  storeDescription    String?       @db.Text
  storeImage          String?
  status              SellerStatus  @default(PENDING)
  verificationStatus  String        @default("pending") // pending, verified, rejected
  bankDetails         String?       @db.Text // JSON string for bank info
  commissionRate      Float         @default(10) // percentage
  totalEarnings       Float         @default(0)
  totalOrders         Int           @default(0)
  rating              Float         @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  analytics           SellerAnalytics?
  promotions          Promotion[]

  @@index([status])
  @@index([verificationStatus])
}

// ============================================================================
// Product Models
// ============================================================================

enum ProductCategory {
  CLOTHING
  ACCESSORIES
}

model Category {
  id          String    @id @default(cuid())
  name        ProductCategory
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@unique([name])
}

model Product {
  id              String    @id @default(cuid())
  sku             String    @unique
  name            String
  description     String    @db.Text
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  
  sellerId        String
  seller          User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  price           Float
  originalPrice   Float?
  discountPercent Float     @default(0)
  stock           Int       @default(0)
  isActive        Boolean   @default(true)
   badge           ProductBadge?
  
  // Variants
  images          ProductImage[]
  sizes           String    @default("") // JSON array: ["S", "M", "L", "XL"]
  colors          String    @default("") // JSON array: ["Black", "White"]
  
  // Ratings & Reviews
  reviews         Review[]
  averageRating   Float     @default(0)
  reviewCount     Int       @default(0)
  
  // Relations
  cartItems       CartItem[]
  wishlistItems   Wishlist[]
  orderItems      OrderItem[]
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sellerId])
  @@index([categoryId])
  @@index([isActive])
}
enum ProductBadge {
  BEST_SELLER
  NEW_ARRIVAL
  SALE
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  imageUrl  String   @db.Text
  altText   String?
  isMain    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

// ============================================================================
// Cart & Wishlist Models
// ============================================================================

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity  Int      @default(1)
  size      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, size, color])
  @@index([userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ============================================================================
// Order Models
// ============================================================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  
  customerId        String
  customer          User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  sellerId          String
  seller            User        @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  
  items             OrderItem[]
  
  subtotal          Float
  taxAmount         Float       @default(0)
  shippingCost      Float       @default(0)
  discountAmount    Float       @default(0)
  totalAmount       Float
  
  status            OrderStatus @default(PENDING)
  paymentStatus     String      @default("pending") // pending, completed, failed
  paymentMethod     String?     // stripe, paypal, etc
  
  // Shipping Info
  shippingAddress   String      @db.Text // JSON string
  billingAddress    String?     @db.Text
  phoneNumber       String?
  
  // Tracking
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  
  // Discounts
  couponId          String?
  coupon            Coupon?     @relation(fields: [couponId], references: [id])
  
  notes             String?     @db.Text
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([customerId])
  @@index([sellerId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float    // Price at time of order
  size      String?
  color     String?
  
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ============================================================================
// Review & Rating Models
// ============================================================================

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  rating    Int      // 1-5
  title     String?
  comment   String?  @db.Text
  images    String   @default("") // JSON array of image URLs
  
  isVerifiedPurchase Boolean @default(false)
  helpful   Int      @default(0)
  unhelpful Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

// ============================================================================
// Discount & Coupon Models
// ============================================================================

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id              String        @id @default(cuid())
  code            String        @unique
  description     String?
  discountType    DiscountType  @default(PERCENTAGE)
  discountValue   Float
  maxUses         Int?
  currentUses     Int           @default(0)
  minOrderAmount  Float         @default(0)
  maxDiscountAmount Float?
  
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean       @default(true)
  
  orders          Order[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([isActive])
  @@index([code])
}

model Discount {
  id              String        @id @default(cuid())
  productId       String
  discountType    DiscountType  @default(PERCENTAGE)
  discountValue   Float
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ============================================================================
// Promotion Model (for sellers)
// ============================================================================

model Promotion {
  id              String    @id @default(cuid())
  sellerId        String
  seller          SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?   @db.Text
  discountValue   Float
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sellerId])
}

// ============================================================================
// Analytics Models
// ============================================================================

model SellerAnalytics {
  id                String  @id @default(cuid())
  sellerProfileId   String  @unique
  sellerProfile     SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  
  totalRevenue      Float   @default(0)
  totalSales        Int     @default(0)
  totalOrders       Int     @default(0)
  totalRefunds      Float   @default(0)
  avgOrderValue     Float   @default(0)
  conversionRate    Float   @default(0)
  
  lastUpdated       DateTime @default(now()) @updatedAt
}

model PlatformAnalytics {
  id                String   @id @default(cuid())
  
  totalRevenue      Float    @default(0)
  totalOrders       Int      @default(0)
  totalUsers        Int      @default(0)
  totalSellers      Int      @default(0)
  totalProducts     Int      @default(0)
  
  date              DateTime @unique @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
